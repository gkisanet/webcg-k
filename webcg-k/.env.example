# VITE_GEMINI_API_KEY=your-key-here

# 방송 그래픽(Broadcast Graphics) renderer motion capability
# true로 설정하려면 실제 renderer build 또는 호스트 페이지가 GSAP을 제공해야 합니다.
# 값이 false/off/0이거나 미설정이면 GSAP driver motion은 Quality Gate에서 warning으로 표시되고 WAAPI로 fallback합니다.
VITE_WEBCGK_MOTION_GSAP_ENABLED=false
